{
  "name": "@promptshield/optimizer",
  "private": true,
  "version": "0.1.0",
  "description": "Transitional TypeScript helper surface for the Python-owned optimizer runtime.",
  "type": "module",
  "scripts": {
    "dev:helper": "tsx watch src/server.ts",
    "typecheck:helper": "tsc --noEmit",
    "test:helper": "node --import tsx --test src/*.test.ts",
    "test:python": "python -m pytest tests -q",
    "typecheck": "pnpm run typecheck:helper",
    "test": "pnpm run test:python"
  },
  "dependencies": {
    "@promptshield/contracts": "workspace:*",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
