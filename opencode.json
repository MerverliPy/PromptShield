{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-mini",
  "default_agent": "build",
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "instructions": [
    "memory/HANDOFF.md",
    "docs/phases/ACTIVE.md",
    "packages/*/AGENT.md",
    "apps/*/AGENT.md",
    "services/*/AGENT.md"
  ],
  "agent": {
    "build": {
      "model": "openai/gpt-5.4"
    },
    "plan": {
      "model": "openai/gpt-5.4-mini",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    }
  }
}
