{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-mini",
  "default_agent": "controller",
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "instructions": [
    "AGENTS.md",
    "memory/HANDOFF.md",
    "docs/phases/ACTIVE.md"
  ],
  "agent": {
    "controller": {
      "model": "openai/gpt-5.4-mini",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "planner": {
      "model": "openai/gpt-5.4-mini",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "implementation": {
      "model": "openai/gpt-5.4",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    },
    "review": {
      "model": "openai/gpt-5.4-mini",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "refactor": {
      "model": "openai/gpt-5.4-mini",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    }
  }
}
