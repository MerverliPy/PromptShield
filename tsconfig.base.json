{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@promptshield/contracts/*": ["packages/contracts/src/*"],
      "@promptshield/policy/*": ["packages/policy/src/*"],
      "@promptshield/ui/*": ["packages/ui/src/*"]
    }
  }
}
