{
  "name": "promptshield",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev:dashboard": "pnpm --dir apps/dashboard dev",
    "dev:proxy": "pnpm --dir apps/proxy dev",
    "dev:worker": "pnpm --dir apps/worker dev",
    "typecheck": "pnpm -r --if-present typecheck",
    "typecheck:optimizer": "pnpm --filter @promptshield/optimizer typecheck",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "test:optimizer": "pnpm --filter @promptshield/optimizer test",
    "format": "pnpm -r --if-present format"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
